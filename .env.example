# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# --- JWT ---
# Required. Use a long random string (min 32 chars).
JWT_SECRET=your-super-secret-jwt-key-change-me

# --- Database (dev profile) ---
# Defaults to the docker-compose values if not set.
DB_URL=jdbc:postgresql://localhost:5432/workouttracker
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Seeded admin user ---
# Used by DataInitializer on first startup.
# ADMIN_PASSWORD has NO default in the base config — production deployments must set it
# or the application will fail to start. Dev and test profiles default to admin123 locally.
ADMIN_PASSWORD=admin123
# Username and email default to "admin" / "admin@workouttracker.com"; override if needed.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@workouttracker.com
